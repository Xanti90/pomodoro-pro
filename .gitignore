# ══ FOCUMO — .gitignore ══════════════════════════════════
# Nunca subir credenciales, bases de datos locales ni logs.

# ── Base de datos local ──────────────────────────────────
data/
*.db
*.db-bak
*.json.bak

# ── Credenciales y secretos ──────────────────────────────
.env
*.env
.env.*
.secret_key
data/.secret_key
google_token.json
*_token.json
*_credentials.json
client_secret*.json
service_account*.json

# ── Python ───────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
.venv/
venv/
env/
ENV/
dist/
build/
*.egg-info/

# ── macOS ────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*

# ── Logs y runtime ───────────────────────────────────────
*.log
logs/
nohup.out
*.pid
*.sock

# ── IDE ──────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.swp
*~

# ── Deploy ───────────────────────────────────────────────
.vercel
.render
staticfiles/
